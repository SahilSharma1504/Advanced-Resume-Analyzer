{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. Start Python Backend",
            "type": "shell",
            "command": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :5000') do @if NOT \"%a\"==\"0\" taskkill /F /PID %a >nul 2>&1 & pip install -r requirements.txt & python app.py",
            "options": {
                "cwd": "${workspaceFolder}/python-backend"
            },
            "presentation": {
                "group": "servers",
                "reveal": "always",
                "panel": "new"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "2. Start Java API Gateway",
            "type": "shell",
            "command": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :8081') do @if NOT \"%a\"==\"0\" taskkill /F /PID %a >nul 2>&1 & mvnw spring-boot:run",
            "options": {
                "cwd": "${workspaceFolder}/java-backend"
            },
            "presentation": {
                "group": "servers",
                "reveal": "always",
                "panel": "new"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "3. Start Frontend & Browser",
            "type": "shell",
            "command": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :8000') do @if NOT \"%a\"==\"0\" taskkill /F /PID %a >nul 2>&1 & start http://localhost:8000 & python -m http.server 8000",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "group": "servers",
                "reveal": "always",
                "panel": "new"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Launch Resume Analyzer (All Services)",
            "dependsOn": [
                "1. Start Python Backend",
                "2. Start Java API Gateway",
                "3. Start Frontend & Browser"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
